  object UpdateSQL: TUpdateSQL
    ModifySQL.Strings = (
      'UPDATE Dev_Loading'
      'SET'
      '  FDTeam = :FDTeam,'
      '  KFLX = :Type,'
      '  RealScore= :RealScore,'
      '  Score= :Score,'
      '  RFCDate= :RFCDate,'
      '  Finished= :Finished,'
      '  NoDev= :NoDev,'
      '  UserID = :UserID,'
      '  UserDate = :UserDate,'
      '  YN = :YN'
      'WHERE'
      '  JiJie= :OLD_JiJie AND'
      '  FD= :OLD_FD AND'
      '  DEVCODE= :OLD_DEVCODE'
      ''
      '')
    InsertSQL.Strings = (
      'INSERT INTO Dev_Loading'
      
        '(JiJie, FD, DEVCODE,FDTeam ,KFLX, RealScore, Score, RFCDate, Fin' +
        'ished,NoDev,UserID, UserDate, YN)'
      'VALUES'
      
        '(:JiJie, :FD, :DEVCODE, :FDTeam,:Type, :RealScore, :Score, :RFCD' +
        'ate, :Finished, :NoDev, :UserID, :UserDate, :YN)'
      '')
    Left = 1037
    Top = 432
  end
  object QueryTempExcel: TQuery
    DatabaseName = 'DB'
    DataSource = DS1
    SQL.Strings = (
      
        'select MAX(FDGroups.FDTeam) AS FDTeam, main2.jijie,main2.fd,main' +
        '2.devcode,main2.xieming,DevType,main2.Type,convert(float,main2.R' +
        'ealScore) RealScore,convert(float,main2.Score) Score,main2.XieXi' +
        'ng,Dev_Loading.RFCDate,Dev_Loading.Finished,Dev_Loading.USERID,D' +
        'ev_Loading.USERDATE,Dev_Loading.YN from ('
      
        'select jijie,fd,devcode,xieming,Type,case when rank='#39'1'#39' then Sco' +
        're else '#39'1'#39' end RealScore,Score,XieXing,DevType from ('
      
        'select kfxxzl.devcode,kfxxzl.xieming,kfxxzl.XieXing,kfxxzl.sheha' +
        'o,kfxxzl.jijie,kfxxzl.khdh,FD,DevType, case '
      'when kflx='#39'TN'#39' then '#39'TotalNew'#39' '
      'when kflx='#39'TN+'#39' then '#39'TotalNew+'#39
      'when kflx='#39'CU'#39' then '#39'NewColor'#39' '
      'when kflx='#39'NU'#39' then '#39'NewUpper'#39' '
      'when kflx='#39'NU+'#39' then '#39'NewUpper+'#39' '
      'when kflx='#39'NU-'#39' then '#39'NewUpper-'#39' '
      'when kflx='#39'NG'#39' then '#39'NewGraphic'#39' '
      'when kflx='#39'MU'#39' then '#39'NewMaterial'#39' '
      'when kflx='#39'MU+'#39' then '#39'NewMaterial+'#39' '
      'when kflx='#39'NP'#39' then '#39'NewProcess'#39' '
      'when kflx='#39'NT'#39' then '#39'NewBottomComponentTooling'#39' '
      'when kflx='#39'ND'#39' then '#39'NewCuttingDies'#39' '
      'else '#39'Error'#39' end Type, '
      'case '
      'when kflx='#39'TN'#39' then '#39'15'#39' '
      'when kflx='#39'TN+'#39' then '#39'20'#39' '
      'when kflx='#39'CU'#39' then '#39'1'#39' '
      'when kflx='#39'NU'#39' then '#39'8'#39' '
      'when kflx='#39'NU+'#39' then '#39'10'#39
      'when kflx='#39'NU-'#39' then '#39'6'#39' '
      'when kflx='#39'NG'#39' then '#39'2'#39' '
      'when kflx='#39'MU'#39' then '#39'3'#39' '
      'when kflx='#39'MU+'#39' then '#39'4'#39' '
      'when kflx='#39'NP'#39' then '#39'5'#39' '
      'when kflx='#39'NT'#39' then '#39'4'#39' '
      'when kflx='#39'ND'#39' then '#39'3'#39' '
      
        'else '#39'9999'#39' end Score,row_number() OVER (PARTITION BY xiexing,FD' +
        ' ORDER BY FD) as rank,kflx '
      'from kfxxzl '
      'left join kfzl_GS on kfzl_GS .KHBH=kfxxzl.KHDH'
      
        'LEFT JOIN XXZLKF ON kfxxzl.XieXing = XXZLKF.XieXing AND KFXXZL.S' +
        'heHao = XXZLKF.SheHao'
      'where'
      
        'kfxxzl.devcode is not null and kfxxzl.devcode<>'#39#39' and kfzl_GS.GS' +
        'BH='#39'CDC'#39' and fd=:fd and jijie=:jijie'
      
        'AND ((XXZLKF.TRANSFER = '#39'0'#39' OR XXZLKF.TRANSFER is null) AND (XXZ' +
        'LKF.Hold = '#39'0'#39' OR XXZLKF.Hold is null) AND (XXZLKF.DROPPED = '#39'0'#39 +
        ' OR XXZLKF.DROPPED is null))'
      'and kfxxzl.xieming not like '#39'%NULLIFY%'#39'  )main1 )main2 '
      'LEFT JOIN Busers ON Busers.Engname = main2.FD '
      'LEFT JOIN FDGroups ON FDGroups.FDID = Busers.USERID'
      
        'LEFT JOIN Dev_Loading ON main2.jijie = Dev_Loading.jijie AND mai' +
        'n2.fd = Dev_Loading.fd AND main2.devcode = Dev_Loading.devcode '
      'WHERE RFCDate is null and (Finished<>'#39'1'#39' or Finished IS NULL)'
      
        'GROUP BY main2.jijie, main2.fd, main2.devcode, main2.xieming, ma' +
        'in2.Type, main2.RealScore, main2.Score, main2.XieXing,main2.DevT' +
        'ype,RFCDate,Finished,Dev_Loading.USERID,USERDATE,Dev_Loading.YN'
      'order by main2.FD,main2.XieXing desc'
      '')
    Left = 1193
    Top = 385
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'fd'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'jijie'
        ParamType = ptUnknown
      end>
