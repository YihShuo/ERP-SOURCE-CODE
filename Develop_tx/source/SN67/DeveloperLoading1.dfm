    object TabSheet2: TTabSheet
      Caption = 'Tech Level Definitions'
      ImageIndex = 1
      object Memo2: TMemo
        Left = 0
        Top = 0
        Width = 1522
        Height = 708
        Align = alClient
        Lines.Strings = (
          
            'Tech Level is the attribute used to identify the technical compl' +
            'exity of a specific project or sample request.  Tech Level helps' +
            ' classify the amount of design, development, and commercializati' +
            'on work required during the product creation process and product' +
            'ion phase.  The final Tech '
          
            'Level value will default to the highest Tech Level as applicable' +
            ' (e.g., NU will trump NP if a New Process is used on a New Upper' +
            '). '#25216#34899#39006#21029#20418#25351#29305#23450#30340#22411#39636'/'#27171#21697#38656#27714#30340#25216#34899#35079#38620#24230#65292#21487#21332#21161#38283#30332#38542#27573#26178#20998#39006#23450#32681#35373#35336'/'#38283#30332'/'#25216#36681#38656#35201#30340#24037#20316#37327#12290#21516#38795#22411#21487#20197#21516#26178#26377#35079#25976#30340 +
            #25216#34899
