  object Query1: TQuery
    DatabaseName = 'dB'
    SQL.Strings = (
      
        'SELECT main3.jijie, main3.fd, MAX(main3.FDTeam) AS FDTeam, SUM(m' +
        'ain3.ConditionalRealScore) AS RealScore from ('
      
        'SELECT main2.jijie, main2.fd, main2.devcode, main2.xieming, main' +
        '2.Type, CONVERT(FLOAT, MAX(main2.RealScore)) AS RealScore, CONVE' +
        'RT(FLOAT, MAX(main2.Score)) AS Score,'
      
        ' MAX(FDGroups.FDTeam) AS FDTeam, main2.DevType,Dev_Loading.RFCDa' +
        'te, Dev_Loading.Finished, Dev_Loading.USERID, Dev_Loading.USERDA' +
        'TE, Dev_Loading.YN,'
      
        'CASE WHEN Dev_Loading.NoDev = 1 THEN 0 ELSE CONVERT(FLOAT, MAX(m' +
        'ain2.RealScore)) END AS ConditionalRealScore FROM ('
      
        'SELECT jijie, fd, devcode, xieming, Type, CASE WHEN rank = '#39'1'#39' T' +
        'HEN Score ELSE '#39'1'#39' END RealScore, Score, DevType FROM ('
      
        'SELECT kfxxzl.devcode, kfxxzl.xieming, kfxxzl.shehao, kfxxzl.jij' +
        'ie, kfxxzl.khdh, FD, DevType,'
      'case'
      'when kfxxzl.kflx='#39'TN'#39'  then '#39'TotalNew'#39
      'when kfxxzl.kflx='#39'TN+'#39' then '#39'TotalNew+'#39
      'when kfxxzl.kflx='#39'CU'#39'  then '#39'NewColor'#39
      'when kfxxzl.kflx='#39'NU'#39'  then '#39'NewUpper'#39
      'when kfxxzl.kflx='#39'NU+'#39' then '#39'NewUpper+'#39
      'when kfxxzl.kflx='#39'NU-'#39' then '#39'NewUpper-'#39
      'when kfxxzl.kflx='#39'NG'#39'  then '#39'NewGraphic'#39
      'when kfxxzl.kflx='#39'MU'#39'  then '#39'NewMaterial'#39
      'when kfxxzl.kflx='#39'MU+'#39' then '#39'NewMaterial+'#39
      'when kfxxzl.kflx='#39'NP'#39'  then '#39'NewProcess'#39
      'when kfxxzl.kflx='#39'NT'#39'  then '#39'NewBottomComponentTooling'#39
      'when kfxxzl.kflx='#39'ND'#39'  then '#39'NewCuttingDies'#39
      'else '#39'Error'#39' end Type,'
      'case'
      'when kfxxzl.kflx='#39'TN'#39' then '#39'15'#39
      'when kfxxzl.kflx='#39'TN+'#39' then '#39'20'#39
      'when kfxxzl.kflx='#39'CU'#39' then '#39'1'#39
      'when kfxxzl.kflx='#39'NU'#39' then '#39'8'#39
      'when kfxxzl.kflx='#39'NU+'#39' then '#39'10'#39
      'when kfxxzl.kflx='#39'NU-'#39' then '#39'6'#39
      'when kfxxzl.kflx='#39'NG'#39' then '#39'2'#39
      'when kfxxzl.kflx='#39'MU'#39' then '#39'3'#39
      'when kfxxzl.kflx='#39'MU+'#39' then '#39'4'#39
      'when kfxxzl.kflx='#39'NP'#39' then '#39'5'#39
      'when kfxxzl.kflx='#39'NT'#39' then '#39'4'#39
      'when kfxxzl.kflx='#39'ND'#39' then '#39'3'#39
      
        'else '#39'9999'#39'  end Score,row_number() OVER (PARTITION BY kfxxzl.xi' +
        'exing,kfxxzl.FD ORDER BY FD) as rank,kfxxzl.kflx'
      'from kfxxzl'
      'left join kfzl_GS on kfzl_GS .KHBH=kfxxzl.KHDH'
      
        'LEFT JOIN XXZLKF ON kfxxzl.XieXing = XXZLKF.XieXing AND kfxxzl.S' +
        'heHao = XXZLKF.SheHao'
      
        'where kfxxzl.devcode is not null and kfxxzl.devcode<>'#39#39' and kfzl' +
        '_GS.GSBH='#39'CDC'#39
      
        'AND ((XXZLKF.TRANSFER = '#39'0'#39' OR XXZLKF.TRANSFER is null) AND (XXZ' +
        'LKF.Hold = '#39'0'#39' OR XXZLKF.Hold is null) AND (XXZLKF.DROPPED = '#39'0'#39 +
        ' OR XXZLKF.DROPPED is null))'
      ' and ('
      '(kfxxzl.jijie like '#39'%25S%'#39')'
      ')'
      ' and ('
      '(kfxxzl.fd like '#39'%ROSE%'#39')'
      ')'
      'and kfxxzl.xieming not like '#39'%NULLIFY%'#39'  )main1 )main2'
      'LEFT JOIN Busers ON Busers.Engname = main2.FD'
      'left join FDGroups on FDGroups.FDID = Busers.USERID'
      
        'LEFT JOIN Dev_Loading ON main2.jijie = Dev_Loading.jijie AND mai' +
        'n2.fd = Dev_Loading.fd AND main2.devcode = Dev_Loading.devcode'
      ' where ('
      '(FDGroups.FDTeam like '#39'%CONS%'#39')'
      ')'
      
        'GROUP BY main2.jijie, main2.fd, main2.devcode, main2.xieming, ma' +
        'in2.Type,main2.DevType, RFCDate, Finished, Dev_Loading.USERID, U' +
        'SERDATE, Dev_Loading.YN,Dev_Loading.NoDev) main3'
      'GROUP BY main3.jijie, main3.fd'
      'ORDER BY main3.jijie,RealScore DESC')
    Left = 977
    Top = 337
    object Query1jijie: TStringField
      FieldName = 'jijie'
      FixedChar = True
    end
    object Query1RealScore: TFloatField
      FieldName = 'RealScore'
    end
    object Query1FD: TStringField
      FieldName = 'FD'
      FixedChar = True
    end
    object Query1FDTeam: TStringField
      FieldName = 'FDTeam'
    end
  end
  object Query2: TQuery
    DatabaseName = 'dB'
    DataSource = DS1
    SQL.Strings = (
      
        'select main2.jijie,main2.fd,main2.devcode,main2.xieming,main2.Ty' +
        'pe,convert(float,MAX(main2.RealScore)) RealScore,convert(float,M' +
        'AX(main2.Score)) Score, MAX(FDGroups.FDTeam) AS FDTeam,DevType,D' +
        'ev_Loading.RFCDate,Dev_Loading.Finished,Dev_Loading.USERID,Dev_L' +
        'oading.USERDATE,Dev_Loading.YN,Dev_Loading.NoDev,main2.XieXing f' +
        'rom ('
      
        'select jijie,fd,devcode,xieming,Type,case when rank='#39'1'#39' then Sco' +
        're else '#39'1'#39' end RealScore,Score,DevType,XieXing from ('
      
        'select kfxxzl.devcode,kfxxzl.xieming,kfxxzl.shehao,kfxxzl.jijie,' +
        'kfxxzl.khdh,kfxxzl.FD as FD,kfxxzl.DevType as DevType, case '
      'when kfxxzl.kflx='#39'TN'#39' then '#39'TotalNew'#39' '
      'when kfxxzl.kflx='#39'TN+'#39' then '#39'TotalNew+'#39
      'when kfxxzl.kflx='#39'CU'#39' then '#39'NewColor'#39' '
      'when kfxxzl.kflx='#39'NU'#39' then '#39'NewUpper'#39' '
      'when kfxxzl.kflx='#39'NU+'#39' then '#39'NewUpper+'#39' '
      'when kfxxzl.kflx='#39'NU-'#39' then '#39'NewUpper-'#39' '
      'when kfxxzl.kflx='#39'NG'#39' then '#39'NewGraphic'#39' '
      'when kfxxzl.kflx='#39'MU'#39' then '#39'NewMaterial'#39' '
      'when kfxxzl.kflx='#39'MU+'#39' then '#39'NewMaterial+'#39' '
      'when kfxxzl.kflx='#39'NP'#39' then '#39'NewProcess'#39' '
      'when kfxxzl.kflx='#39'NT'#39' then '#39'NewBottomComponentTooling'#39' '
      'when kfxxzl.kflx='#39'ND'#39' then '#39'NewCuttingDies'#39' '
      'else '#39'Error'#39' end Type, '
      'case '
      'when kfxxzl.kflx='#39'TN'#39' then '#39'15'#39' '
      'when kfxxzl.kflx='#39'TN+'#39' then '#39'20'#39' '
      'when kfxxzl.kflx='#39'CU'#39' then '#39'1'#39' '
      'when kfxxzl.kflx='#39'NU'#39' then '#39'8'#39' '
      'when kfxxzl.kflx='#39'NU+'#39' then '#39'10'#39
      'when kfxxzl.kflx='#39'NU-'#39' then '#39'6'#39' '
      'when kfxxzl.kflx='#39'NG'#39' then '#39'2'#39' '
      'when kfxxzl.kflx='#39'MU'#39' then '#39'3'#39' '
      'when kfxxzl.kflx='#39'MU+'#39' then '#39'4'#39' '
      'when kfxxzl.kflx='#39'NP'#39' then '#39'5'#39' '
      'when kfxxzl.kflx='#39'NT'#39' then '#39'4'#39' '
      'when kfxxzl.kflx='#39'ND'#39' then '#39'3'#39' '
      
        'else '#39'9999'#39' end Score,row_number() OVER (PARTITION BY kfxxzl.xie' +
        'xing,kfxxzl.FD ORDER BY kfxxzl.FD) as rank,kfxxzl.kflx,kfxxzl.Xi' +
        'eXing '
      'from kfxxzl '
      'left join kfzl_GS on kfzl_GS .KHBH=kfxxzl.KHDH'
      
        'LEFT JOIN XXZLKF ON kfxxzl.XieXing = XXZLKF.XieXing AND KFXXZL.S' +
        'heHao = XXZLKF.SheHao'
      
        'LEFT JOIN ypzl ON ypzl.XieXing = kfxxzl.XieXing AND ypzl.SheHao ' +
        '= kfxxzl.SheHao'
      
        'left join CBYtoSpec on CBYtoSpec.XieXing=KFXXZL.XieXing and CBYt' +
        'oSpec.SheHao=KFXXZL.SheHao'
      'where'
      
        'kfxxzl.devcode is not null and kfxxzl.devcode<>'#39#39' and kfzl_GS.GS' +
        'BH='#39'CDC'#39
      'AND ('
      
        '(CBYtoSpec.XieXing IS NOT NULL) OR (ypzl.XieXing IS NOT NULL AND' +
        ' ypzl.GSDH='#39'CDC'#39' AND LEFT(ISNULL(YPZL.YPDH,'#39#39'), 3) <> '#39'CBY'#39' AND ' +
        'ypzl.KFJD <> '#39'SEE'#39')'
      ')'
      
        'AND ((XXZLKF.TRANSFER = '#39'0'#39' OR XXZLKF.TRANSFER is null) AND (XXZ' +
        'LKF.Hold = '#39'0'#39' OR XXZLKF.Hold is null) AND (XXZLKF.DROPPED = '#39'0'#39 +
        ' OR XXZLKF.DROPPED is null))'
      'and kfxxzl.fd=:fd and kfxxzl.jijie=:jijie'
      
        'and kfxxzl.xieming not like '#39'%NULLIFY%'#39' and kfxxzl.xieming not l' +
        'ike '#39'%NULIFY%'#39' )main1 )main2'
      'LEFT JOIN Busers ON Busers.Engname = main2.FD '
      'LEFT JOIN FDGroups ON FDGroups.FDID = Busers.USERID'
      
        'LEFT JOIN Dev_Loading ON main2.jijie = Dev_Loading.jijie AND mai' +
        'n2.fd = Dev_Loading.fd AND main2.devcode = Dev_Loading.devcode '
      
        'GROUP BY main2.jijie, main2.fd, main2.devcode, main2.xieming, ma' +
        'in2.Type,main2.DevType,RFCDate,Finished,Dev_Loading.USERID,USERD' +
        'ATE,Dev_Loading.YN,Dev_Loading.NoDev,main2.XieXing'
      'order by main2.FD,main2.DEVCODE desc'
      '')
    UpdateObject = UpdateSQL
    Left = 1033
    Top = 393
    ParamData = <
