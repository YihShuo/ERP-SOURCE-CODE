  object Query3: TQuery
    DatabaseName = 'DB'
    SQL.Strings = (
      ''
      
        'select YPDH,RFIDNO,Season,stage,testno,Article,Complete,FD,WHNO,' +
        'SNO,info,day,overday,SIZ,USERDATE1'
      
        'from (select ypzl.YPDH,RFID_TB.RFIDNO,shoetest.Season,shoetest.s' +
        'tage,shoetest.testno,shoetest.Article,shoetest.Complete,shoetest' +
        '.FD,YPZL.YPCC as SIZ'
      ', case when RFID_TB.WHNO is null or t5.WHNO is null then '
      
        '       '#39'Not in warehouse'#39' else t5.WHNO end as WHNO, case when RF' +
        'ID_TB.SNO is null or t5.SNO is null then '#39'Not in warehouse'#39' else' +
        ' t5.SNO end as SNO'
      
        ',case when t3.WorkID is not null and t3.DEPARTMENT='#39'QC'#39' then t3.' +
        'DEPARTMENT + '#39': '#39' + t3.WorkID + '#39': '#39' + isnull(t3.MEMO,'#39#39') '
      
        '       when t3.WorkID is not null and t3.DEPARTMENT='#39#39' then '#39'DC_' +
        'REF_7D: '#39' + t3.WorkID + '#39': '#39' + isnull(t3.MEMO,'#39#39') '
      
        '       when t3.WorkID is not null and t3.DEPARTMENT='#39'DC_REF'#39' the' +
        'n '#39'DC_REF_30D: '#39' + t3.WorkID + '#39': '#39' + isnull(t3.MEMO,'#39#39') else '#39#39 +
        ' end as info '
      
        ',case when ShoeTest.Complete is not null then DATEDIFF(day,ShoeT' +
        'est.Complete,GETDATE()) else 0 end as day, '
      
        '       case when ShoeTest.Complete is not null and DATEDIFF(day,' +
        'ShoeTest.Complete,GETDATE())>10 then DATEDIFF(day,ShoeTest.Compl' +
        'ete,GETDATE())-10 else 0 end as overday'
      
        '       ,case when t3.IO='#39'MOVE OUT'#39' then t3.USERDATE else NULL en' +
        'd USERDATE1'
      'from shoetest'
      'left join shoetestplan on shoetest.testno = shoetestplan.testno'
      
        'left join ShoeTestPlanHis on shoetest.testno = ShoeTestPlanHis.t' +
        'estno and ShoeTestPlanHis.GXLB='#39'C'#39' and ShoeTestPlanHis.Seq='#39'1'#39' '
      
        'left join shoetestDelay on shoetestDelay.testno=shoetest.testno ' +
        'and shoetestDelay.GXLB='#39'F'#39' '
      'left join shoetestDetail DR on DR.YYBH=shoetestDelay.DR'
      'left join shoetestDetail DP on DP.YYBH=DR.Class'
      'left join ypzl on ypzl.YPDH=shoetest.YPDH'
      
        'left join kfxxzl on kfxxzl.xiexing=ypzl.XieXing and kfxxzl.sheha' +
        'o=ypzl.shehao'
      ''
      
        'left join LIY_TYXUAN.dbo.RFID_TB RFID_TB on RFID_TB.TESTNO = Sho' +
        'eTest.TestNo '
      ''
      
        'left join LIY_TYXUAN.dbo.RFID_TRACK t1 on RFID_TB.TESTNO = t1.Te' +
        'stNo and RFID_TB.RFIDNO = t1.RFIDNO '
      
        '          and t1.USERDATE = (select MIN(USERDATE) from LIY_TYXUA' +
        'N.dbo.RFID_TRACK t2 '
      
        '                             where t2.TESTNO = t1.TESTNO and t2.' +
        'RFIDNO = t1.RFIDNO and t2.PROGRAM_ID='#39'DCWH_STAR'#39') '
      
        'left join LIY_TYXUAN.dbo.RFID_TRACK t3 on RFID_TB.TESTNO = t3.Te' +
        'stNo and RFID_TB.RFIDNO = t3.RFIDNO '
      
        '          and t3.USERDATE = (select MAX(USERDATE) from LIY_TYXUA' +
        'N.dbo.RFID_TRACK t2 '
      
        '                             where t2.TESTNO = t3.TESTNO and t2.' +
        'RFIDNO = t3.RFIDNO and t2.PROGRAM_ID='#39'DCWH_STAR'#39') '
      
        'left join LIY_TYXUAN.dbo.RFID_WH t5 on t5.WHNO=RFID_TB.WHNO and ' +
        't5.SNO=RFID_TB.SNO '
      
        '          and EXISTS (select WHNO,SNO from LIY_TYXUAN.dbo.RFID_W' +
        'H t2 where t5.WHNO=t2.WHNO and t2.SNO='#39'#####'#39') '
      
        'left join LIY_TYXUAN.dbo.RFID_TRACK t6 on RFID_TB.TESTNO = t6.Te' +
        'stNo and RFID_TB.RFIDNO = t6.RFIDNO '
      
        #9#9#9#9#9' and t6.USERDATE = (select MAX(USERDATE) from LIY_TYXUAN.db' +
        'o.RFID_TRACK t2 '
      
        '                             where t2.TESTNO = t6.TESTNO and t2.' +
        'RFIDNO = t6.RFIDNO) '
      'left join ('
      
        #9'select sum(qty) qty,parts,testno from shoetest2 where parts='#39'BW' +
        '01'#39
      #9'group by parts,testno)bw01 on bw01.testno=shoetest.testno'
